{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Runtime": {
    "PlatformTarget": "onprem"
  },
  "Authentication": {
    "Authority": "https://id.example.com/realms/oal",
    "Issuer": "oal.identity",
    "Audience": "oal.api",
    "RequireHttpsMetadata": true
  },
  "Authorization": {
    "RequiredScope": "oal.api",
    "TenantClaim": "tenant_id"
  },
  "Frontend": {
    "AllowedOrigins": [
      "https://app.example.com"
    ]
  },
  "FrontendAuth": {
    "Authority": "https://id.example.com/realms/oal",
    "Realm": "oal",
    "ClientId": "web-app",
    "Scope": "openid profile email",
    "RedirectUri": "https://app.example.com/app",
    "PostLogoutRedirectUri": "https://app.example.com/login",
    "RegistrationUrl": ""
  },
  "Edge": {
    "PublicUrl": "https://app.example.com",
    "TlsMode": "onprem-nginx",
    "KeycloakPublicUrl": "https://id.example.com/realms/oal",
    "GatewayInternalUrl": "http://gateway-api:8080"
  },
  "InternalServices": {
    "Services": [
      {
        "Name": "identity",
        "BaseUrl": "http://localhost:5001"
      },
      {
        "Name": "catalog",
        "BaseUrl": "http://localhost:5002"
      }
    ]
  },
  "Persistence": {
    "Provider": "postgres",
    "ConnectionString": "Host=localhost;Port=5432;Database=oal;Username=oal;Password=oal"
  },
  "Messaging": {
    "Broker": "rabbitmq",
    "Host": "localhost",
    "Port": 5672,
    "Username": "oal",
    "Password": "oal",
    "VirtualHost": "/",
    "Exchange": "oal.events"
  },
  "Encryption": {
    "ApplicationName": "oal-platform"
  },
  "AllowedHosts": "*"
}
