# Environment scope: onprem
# Consumer: stack.hardened.yml and lifecycle deploy/run scripts.
# Secret keys: values below are placeholders and MUST be replaced in real environments.

POSTGRES_USERNAME=oal
POSTGRES_PASSWORD=change-me
RABBITMQ_USERNAME=oal
RABBITMQ_PASSWORD=change-me
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
PERSISTENCE_CONNECTION_STRING=Host=postgres;Port=5432;Database=oal;Username=oal;Password=change-me

EDGE_PUBLIC_URL=https://app.example.com
TLS_MODE=onprem-nginx
KEYCLOAK_PUBLIC_URL=https://id.example.com/realms/oal
GATEWAY_INTERNAL_URL=http://gateway-api:8080
