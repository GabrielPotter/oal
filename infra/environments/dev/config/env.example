# Environment scope: dev
# Consumer: lifecycle run/build scripts and local compose stacks.
# Secrets policy: dev-only defaults; do not use production secrets here.

OAL__GATEWAY__BASEURL=http://localhost:5000
OAL__IDENTITY__BASEURL=http://localhost:5001
OAL__CATALOG__BASEURL=http://localhost:5002
OAL__POSTGRES__CONNECTION=Host=localhost;Port=5432;Database=oal;Username=oal;Password=oal
OAL__RABBITMQ__HOST=localhost
OAL__RABBITMQ__PORT=5672
OAL__RABBITMQ__USERNAME=oal
OAL__RABBITMQ__PASSWORD=oal
OAL__RABBITMQ__VHOST=/
OAL__RABBITMQ__EXCHANGE=oal.events
OAL__REDIS__CONNECTION=localhost:6379
OAL__AUTH__AUTHORITY=http://localhost:8088/realms/oal
OAL__AUTH__TENANT_CLAIM=tenant_id
OAL__FRONTEND__PUBLIC_URL=http://localhost:8080
OAL__FRONTEND__GATEWAY_API_BASE_URL=http://localhost:8080/api
